{
  "name": "@uat-tester/cli",
  "version": "1.0.0",
  "description": "Self-updating end-to-end UAT harness for web applications. Auto-discovers user flows, self-heals selectors, and validates across multiple projects.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "uat": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "playwright": "^1.45.0",
    "@playwright/test": "^1.45.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "glob": "^10.4.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "axe-core": "^4.9.0",
    "allure-playwright": "^2.15.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.14.0",
    "@types/js-yaml": "^4.0.9",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "uat",
    "e2e",
    "testing",
    "playwright",
    "visual-regression",
    "self-healing",
    "auto-discovery",
    "skills",
    "agent",
    "harness"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cplog/uat-tester-skills.git"
  }
